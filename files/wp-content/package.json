{
	"name": "@cassidydc/wp-dev-toolset",
	"version": "1.1.0",
	"description": "CassidyDC WordPress code formatting and linting development toolset",
	"keywords": [
		"eslint",
		"formatter",
		"linter",
		"prettier",
		"stylelint",
		"wordpress"
	],
	"author": {
		"name": "CassidyDC",
		"email": "info@cassidydc.com",
		"url": "https://cassidydc.com"
	},
	"homepage": "https://github.com/CassidyDC/wp-dev-toolset/blob/main/README.md",
	"license": "MIT",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/CassidyDC/wp-dev-toolset"
	},
	"bugs": {
		"url": "https://github.com/CassidyDC/wp-dev-toolset/issues"
	},
	"devDependencies": {
		"@cassidydc/eslint-plugin-wordpress": "^1.2.2",
		"@cassidydc/stylelint-config-w3c-order": "^1.2.2",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^9.39.4",
		"@stylistic/stylelint-config": "^4.0.0",
		"@wordpress/prettier-config": "^4.41.0",
		"eslint": "^9.39.4",
		"eslint-plugin-import-x": "^4.16.2",
		"globals": "^17.4.0",
		"lefthook": "^2.1.4",
		"markdownlint-cli2": "^0.21.0",
		"prettier": "npm:wp-prettier@^3.0.3",
		"prettier-plugin-multiline-arrays": "^4.1.5",
		"stylelint": "^17.4.0",
		"stylelint-config-standard": "^40.0.0",
		"stylelint-config-standard-scss": "^17.0.0",
		"stylelint-declaration-block-no-ignored-properties": "^3.0.0",
		"stylelint-high-performance-animation": "^2.0.0",
		"stylelint-order": "^8.1.1",
		"stylelint-plugin-logical-css": "^2.0.2",
		"typescript-eslint": "^8.57.1"
	},
	"workspaces": [
		"themes/cassidydc-block-theme"
	],
	"overrides": {
		"@wordpress/scripts": {
			"minimatch": "^10.2.4",
			"serialize-javascript": "^7.0.4",
			"webpack-dev-server": "^5.2.3"
		}
	},
	"scripts": {
		"check": "npx prettier . --check",
		"format": "npx prettier . --write",
		"hook:install": "npx lefthook install",
		"lint:docs": "npx markdownlint-cli2 \"**/*.md\"",
		"lint:docs:fix": "npx markdownlint-cli2 \"**/*.md\" --fix",
		"lint:scripts": "npx eslint",
		"lint:scripts:fix": "npx eslint --fix",
		"lint:styles": "npx stylelint \"**/*.{css,scss}\" --ignore-path .gitignore",
		"lint:styles:fix": "npx stylelint \"**/*.{css,scss}\" --ignore-path .gitignore --fix",
		"build:theme": "npm run build --workspace themes/cassidydc-block-theme",
		"start:theme": "npm run start --workspace themes/cassidydc-block-theme"
	}
}
