{
	"name": "cassidydc/wp-dev-toolset",
	"description": "CassidyDC default PHP code formatting, linting, and static analysis development toolset",
	"version": "1.0.0",
	"keywords": [
		"formatter",
		"linter",
		"php",
		"wordpress",
		"wp"
	],
	"homepage": "https://github.com/CassidyDC/wp-dev-toolset/blob/main/README.md",
	"license": "MIT",
	"authors": [
		{
			"name": "CassidyDC",
			"email": "info@cassidydc.com",
			"homepage": "https://cassidydc.com"
		}
	],
	"support": {
		"issues": "https://github.com/CassidyDC/wp-dev-toolset/issues"
	},
	"require-dev": {
		"dealerdirect/phpcodesniffer-composer-installer": "^1.2.1",
		"php-parallel-lint/php-console-highlighter": "^1.0",
		"php-parallel-lint/php-parallel-lint": "^1.4",
		"php-stubs/wordpress-stubs": "^7.0.0",
		"phpstan/extension-installer": "^1.4.3",
		"phpstan/phpstan": "^2.2.2",
		"squizlabs/php_codesniffer": "^3.13.5",
		"swissspidy/phpstan-no-private": "^1.0",
		"szepeviktor/phpstan-wordpress": "^2.0.3",
		"wp-coding-standards/wpcs": "^3.3.0"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"phpstan/extension-installer": true
		}
	},
	"scripts": {
		"analyse": "vendor/bin/phpstan analyse --memory-limit=2G || true",
		"format": "vendor/bin/phpcbf",
		"lint": "vendor/bin/phpcs",
		"syntax": "vendor/bin/parallel-lint --exclude vendor --show-deprecated themes/cassidydc-block-theme"
	}
}
